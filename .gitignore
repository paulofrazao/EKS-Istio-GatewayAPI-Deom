# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example
.terraform.lock.hcl

# Bootstrap workspace keeps local state (bucket stores main workspace state)
terraform/bootstrap/.terraform/
terraform/bootstrap/terraform.tfstate
terraform/bootstrap/terraform.tfstate.backup

# Certificates (sensitive)
certs/*.pem
certs/*.crt
certs/*.key

# OS files
.DS_Store
