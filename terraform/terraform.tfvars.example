# MTKC POC EKS - Example Terraform Variables
# @author Shanaka Jayasundera - shanakaj@gmail.com
#
# Copy this file to terraform.tfvars and customize as needed.
#
# Remote state setup (run once before terraform apply):
#   ./scripts/setup-backend.sh [project_name] [environment] [region]

# Project Settings
environment  = "poc"
project_name = "mtkc"

# Cluster Regions
cluster_a_region = "us-east-1"
cluster_b_region = "us-west-1"

# Network — CIDRs must not overlap
cluster_a_vpc_cidr = "10.0.0.0/16"
cluster_b_vpc_cidr = "10.1.0.0/16"

az_count           = 2
enable_nat_gateway = true

# EKS Configuration (applied to both clusters)
kubernetes_version     = "1.35"
eks_node_count         = 2
eks_node_instance_type = "t3.medium"

# User Node Pool
enable_user_node_pool   = true
user_node_count         = 2
user_node_instance_type = "t3.medium"

# EKS Autoscaling
enable_eks_autoscaling = false
system_node_min_count  = 1
system_node_max_count  = 3
user_node_min_count    = 1
user_node_max_count    = 5

# EKS Logging
enable_logging = false

# ArgoCD Configuration
argocd_version      = "5.51.6"
argocd_service_type = "LoadBalancer"

# TLS Configuration
enable_https          = true
backend_https_enabled = true

# ACM certificate ARNs — each cluster needs a cert in its own region
cluster_a_acm_certificate_arn = ""  # us-east-1 ACM cert ARN
cluster_b_acm_certificate_arn = ""  # us-west-1 ACM cert ARN

# API Gateway Configuration (cluster-a only, optional)
enable_api_gateway          = false
api_gateway_custom_domain   = ""
api_gateway_certificate_arn = ""
enable_api_gateway_logging  = true

# Tags
tags = {
  Project   = "MTKC-POC"
  Purpose   = "Gateway-API-EKS-Integration"
  ManagedBy = "Terraform"
}
